from abc import ABC, abstractmethod

# 1. Define the abstract base class (blueprint)
class PaymentProcessor(ABC):

    @abstractmethod
    def process_payment(self, amount: float):
        """All payment methods must implement this specific action."""
        pass

# 2. Implement the concrete subclasses
class CreditCardProcessor(PaymentProcessor):
    def process_payment(self, amount: float):
        print(f"Processing credit card payment of ${amount}")

class PayPalProcessor(PaymentProcessor):
    def process_payment(self, amount: float):
        print(f"Processing PayPal payment of ${amount}")

# 3. This subclass will fail because it breaks the contract
class CryptoProcessor(PaymentProcessor):
    #pass  # Forgot to implement process_payment!
    def balance(self,amount: float):
        print (f"Checking crypto balance,${amount}")

# --- Execution ---
card = CreditCardProcessor()
card.process_payment(100.0)  # Works perfectly!
paypal = PayPalProcessor()
paypal.process_payment(200.0)  # Works perfectly!
crypto = CryptoProcessor()  # This will raise an error because process_payment is not implemented
crypto.balance(1000)
