from abc import abstractmethod, ABC

class Animal(ABC):
    def __init__(self, name,sound):
        self.name = name
        self.sound=sound
    @abstractmethod
    def speak(self, sound):
        pass

    def eat(self):
        print(f"{self.name} is eating")

class Dog(Animal):
    def __init__(self,name,sound, breed):
        super().__init__(name,sound)
        self.breed=breed

    def details(self):
        print(f"{self.name} details")

    def speak(self, sound):
        print(f"{self.name} is barking, {self.sound}")

dog = Dog("Gloku",'woof!!','Golden Retriever')
dog.speak('Woof!')
dog.eat()
dog.details()

