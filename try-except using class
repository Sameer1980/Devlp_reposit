class bank:
    def __init__(self, name: str, balance: int):
        self.name = name
        self.balance = balance
    def deposit(self, amount: int, division: int) -> int:
        self.balance += amount
        availablebalance = 0
        try:
           availablebalance = self.balance / division
        except Exception as e:
            print(e.args)
        print (availablebalance)
    def withdraw(self,amount: int) -> int:
        self.balance -= amount
        print (f"Available balance after withdrawal: {self.balance}")
        if self.balance < 0:
            raise InsufficientFund("Your balance is low.")

class InsufficientFund(Exception):
    def __init__(self,message):
        super(InsufficientFund,self).__init__(message)

# DRIVER CODE
sbi = bank("SBI",1000)
try:
    sbi.deposit(1000,1)
    sbi.withdraw(5000)
except InsufficientFund as e:
   print (e.args)
else:
    print ("No Mapping Exception")
finally:
    print ("Bank is closed")







