# partial() and reduce() . These tools allow you to pre-configure functions
# or consolidate data iteratively.
# Partial() is a higher order function from the builtin functools module that
# allows you to "freeze" a portion of a function's arguments to create a new,
# simplified function'.
# When you apply partial to a function , it locks in specific positional or
# keyword arguments . The resulting object is a new callable that only requires the
# remaining unassigned arguments to execute .

from functools import partial, reduce

# A standard function with two arguments
def multiply (x,y):
    return x * y

# Create a new function that always multiplies by 2.
double = partial(multiply, 2) # freezes x as 2

# Call the new function with the remaining argument.
print (double(1000))


# Reduce # 1+2=3 -> 3+3=6 -> 6+4=10

numbers = [1,2,3,4]
result = reduce (lambda x,y: x + y, numbers)
print (result)


