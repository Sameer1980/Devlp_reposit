
#The functools module in Python's standard library provides higher-order functions—utilities
# that accept other functions as arguments or return them as results.
# It serves as a toolset for functional programming,
# optimization, and decorator creation.

#Performance optimization and caching.- @cache , @lru_cache, @cached_property
from functools import cache

@cache
def heavy_calculation(*args):
   result = 1
   for n in args:
        result += n
   return result

print (heavy_calculation(1,2,3,4,5,6,7,8,9))

