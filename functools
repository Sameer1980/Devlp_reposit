"""With lru_cache - Fibonacci"""
from functools import lru_cache

@lru_cache(maxsize = None)
def fibonacci(n):
    if n <= 1:
        return n
    return fibonacci(n - 1) + fibonacci(n - 2)

for num in range(15):
    print (f"{fibonacci(num)}")


