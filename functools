# Custom decorator development - When you wrap a function inside a custom decorator
# you accidentally overwrite that outer function's name and documentation.
# @wraps is a decorator from the functools module used inside custom decorators
# to copy the original function's metadata (like it's name , docstring and annotations)
# to the inner wrapper function.
# @wraps updates the wrapper to preserve - __name__, __doc__, __annotations__,__wrapped__

#Without wraps
def my_decorator(func):
    def wrapper(*args, **kwargs):
        return func(*args, **kwargs)
    return wrapper

@my_decorator
def add(a, b):
    """Adds two numbers together."""
    return a + b

print(add.__name__)  # Outputs: 'wrapper'
print(add.__doc__)   # Outputs: None

# With @wraps
from functools import wraps
def my_decorator(func):
    @wraps(func) # copies metadata from func to wrapper.
    def wrapper(*args, **kwargs):
        return func(*args, **kwargs)
    return wrapper

@my_decorator
def add(a, b):
    """Adds two numbers together."""
    return a + b

print(add.__name__)  # Outputs: 'wrapper'
print(add.__doc__)   # Outputs: None


