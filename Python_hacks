# Drop this tiny helper script in every project for logging.
import logging
def get_logger(name = "app"):
    logging.basicConfig(
        level = logging.INFO,
        filename = 'app.log',
        filemode = 'a',
        format="%(asctime)s [%(levelname)s]: %(message)s"
    )
    return logging.getLogger(name)

log = get_logger()
log.info("Automation started")

# Auto caching function results. Everytime URL is requested , its served from memory instead of hitting
# the network.

from functools import lru_cache
import requests
@lru_cache(maxsize = None)
def get_data(url):
    return requests.get(url).text

