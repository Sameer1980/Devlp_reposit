# A Python decorator is a design pattern that allows you to modify or extend the
# behavior of a function or class without permanently changing its source code.
# Technically, a decorator is a higher-order function that takes another function
# as an argument, adds some wrapper functionality, and returns a new function.

# Core Concept:
# Decorators leverage the fact that functions in Python are first-class objects.
# This means they can be passed around as arguments and returned from other
# functions just like strings or integers.

# Using a decorator is as simple as placing the @decorator_name syntax directly
# above your function definition.

# This syntax:
# @my_decorator
# def my_function():
#     pass

# Is exactly equivalent to writing:
# my_function = my_decorator(my_function)

def my_decorator(func):
    def wrapper():
        print ("Something is happening before the function is called.")
        func()
        print ("Something is happening after the function is called.")
    return wrapper

@my_decorator
def say_hello():
    print ("Hello!!")

say_hello()

# A Python decorator has two return statements to handle two separate layers of execution:
# replacing the original function and passing the actual data.
# A standard decorator looks like this:

def my_decorator(func):
    def wrapper(*args, **kwargs):
        # 1. Do something before the original function
        result = func(*args, **kwargs)
        # 2. Do something after
        return result  # Return statement 2: Returns the original function's result
    return wrapper     # Return statement 1: Returns the wrapper function
#
# 1. Returning the Wrapper Function
# What it does: The outer function returns the wrapper function.
# Why it's needed: Decorators work by replacing the original function with the wrapper.'
#  ' When you decorate a function (e.g., using @my_decorator), '
#    'Python essentially runs: my_function = my_decorator(my_function). '
#    'Without this outer return, your original function would disappear or become None.'

# 2. Returning the Original Function('s Result'
# 'What it does: The inner wrapper function returns the result of executing the '
#  'actual target function.'
#  'Why it's needed: If the wrapper intercepts the call but fails to return the result,
# your decorated functions will always return None when executed.
# This ensures any value computed by your function successfully bubbles up to the caller.

print("\n\n")
def new_decorator(original_func):
    def wrap_func():
        print(f"Print some extra code before the original function!")
        original_func()
        print(f"Print some extra code after the original function!")
        return original_func
    return wrap_func


@new_decorator
def func_needs_decorator():
     print(f"I want to be decorated!!")

func_needs_decorator()

print ("\n\n")
def logger_decorator(func):
    def wrapper(*args, **kwargs):
        print(f"Calling {func.__name__} with args:{args}, kwargs: {kwargs}")
        result = func(*args , **kwargs)
        print(f"{func.__name__} returned: {result}")
        return result
    return wrapper

@logger_decorator
def greet(name, greeting = 'Hello'):
    return f"{greeting},{name} !"

greet("Alice",greeting = "Welcome")

