# 2. Check a true generator expression
gen = (x for x in range(5))
print(type(gen))


# Key differences between a range and a generator object.
#range object                               Generator object
# 1)An iterable sequence(like a lazy list )    An iterator(consumes data)
# 2) Can be looped over multiple times.         Exhausts after a single use.
# 3) Supports (len).Calculates size instantly    No.Has no concept of length.
# 4) indexing(i).Supports direct (indexing       No. Cannot access items by index.
#    and slicing)
#
# In Python, a generator is a special type of function that returns an iterator object,
# allowing you to produce a sequence of values one at a time on demand (lazy evaluation)
# instead of computing them all at once and saving them in memory.
#
# Unlike normal functions that use return to send back a single value and terminate,
# generators use the yield keyword to temporarily pause the function, emit a value,
# and save its entire state so it can resume right where it left off.
#
# Key Benefits
# Memory Efficiency: They do not store the entire data sequence in your RAM,
# making them perfect for massive datasets.
#
# Infinite Streams: Because values are calculated on the fly,
# you can represent infinite data pipelines (like a constant stream of sensor logs)
# without crashing your system.
#
# Cleaner Code: They simplify the process of writing
# custom iterators by eliminating the need to manually build __iter__()
# and __next__() class methods.
#
# When a function contains the yield statement, calling it doesn't run the code instantly.'
# Instead, it creates a generator object.

print ("\n\n")
#1. Define the generator function.
def count_up_to(max_num):
    count = 1
    while count <= max_num:
        yield count   # Pauses here , returns value, saves state
        count += 1

#2. Initialize the generator object.
counter = count_up_to(4)
print (f"Type-{type(counter)}")

#3. Fetch values using a for loop (recommended)
for number in counter:
    print(number)

# You can also pull values manually one by one using the built-in next() function.
# Once a generator runs out of items, it raises a StopIteration exception.

print ("\n\n")
single_counter = count_up_to(3)
print (next(single_counter))
print (next(single_counter))
print (next(single_counter))
#print (next(single_counter)) #Triggers stop iteration exception.

print ("\n\n")
#Using a for loop in Generator.
# 1. Define the generator function
def count_up_to(max_num):
    for count in range(1,max_num):
        yield count  # Pauses here, returns value, saves state

# 2. Initialize the generator object
counter = count_up_to(4)

# 3. Fetch values using a for loop (recommended)
for number in counter:
    print(number)

