# Range is not a generator function in Python.
# While it is commonly called a function, range
# is actually a built-in class type that represents an immutable sequence of numbers.
#
# It is "lazy" like a generator because it does not store all its values
# in memory at once, but it operates quite differently under the hood.

print("\n\n")
import types

# 1. Check range
